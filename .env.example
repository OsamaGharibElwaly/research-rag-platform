# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# Auth Service
AUTH_SERVICE_PORT=8001
DATABASE_URL=sqlite:///./auth.db

# Upload Service
UPLOAD_SERVICE_PORT=8002
UPLOAD_DATABASE_URL=sqlite:///./upload.db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# API Gateway
GATEWAY_PORT=8000
AUTH_SERVICE_URL=http://localhost:8001
UPLOAD_SERVICE_URL=http://localhost:8002

# Parser Service
PARSER_SERVICE_PORT=8003
PARSER_DATABASE_URL=sqlite:///./parser.db
PARSER_SERVICE_URL=http://localhost:8003

NEXT_PUBLIC_API_URL=http://localhost:8000
